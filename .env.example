# ── MongoDB Atlas ─────────────────────────────────────────────────────────
# Free tier at https://mongodb.com/atlas
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=

# ── Linq ──────────────────────────────────────────────────────────────────
# API token from https://linqapp.com → Settings → API Keys
LINQ_API_TOKEN=

# Your Linq from-number in E.164 format (e.g. +12125551234)
LINQ_FROM_NUMBER=

# Webhook HMAC secret from Linq dashboard → Settings → Webhooks
LINQ_WEBHOOK_SECRET=
